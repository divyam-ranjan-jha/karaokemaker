# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.

# URL of the Cloudflare Worker proxy.
# Local dev: start the worker with `cd proxy-worker && npm run dev` (default port 8787)
# Production: set to your deployed worker URL, e.g. https://karaokemaker-proxy.your-account.workers.dev
VITE_WORKER_URL=http://localhost:8787
