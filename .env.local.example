# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit secrets.

# Optional. If unset on localhost, Vite proxies /km-proxy → deployed worker (CORS-safe). On Vercel, the app calls the worker directly.
# Set this only when developing the worker locally:
#   1. cd proxy-worker && npm run dev   (listens on http://localhost:8787)
#   2. Uncomment:
# VITE_WORKER_URL=http://localhost:8787
